#!/bin/bash

DIR="$HOME/dotfiles/Wallpapers"

# pick wallpaper
WALLPAPER=$(find "$DIR" -type f | wofi -dmenu -i -p "Wallpaper")

[ -z "$WALLPAPER" ] && exit 0

# set wallpaper
awww img --transition-type outer "$WALLPAPER"

# generate pywal colors
wal -i "$WALLPAPER"

cp ~/.cache/wal/colors-waybar.css \
   ~/dotfiles/waybar/colors-waybar.css

pkill waybar
waybar &
